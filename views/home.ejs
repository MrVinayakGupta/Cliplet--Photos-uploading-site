<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Pinspire 3D — Discover Your World</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Cabinet+Grotesk:wght@300;400;500;700;800&display=swap" rel="stylesheet"/>
<style>
:root {
  --pink:#FF3CAC; --violet:#784BA0; --blue:#2B86C5;
  --cyan:#00F5D4; --orange:#FF6B35; --yellow:#FFD23F; --lime:#A8FF3E;
  --grad1:linear-gradient(135deg,#FF3CAC 0%,#784BA0 50%,#2B86C5 100%);
  --grad2:linear-gradient(135deg,#00F5D4,#2B86C5);
  --grad3:linear-gradient(135deg,#FF6B35,#FFD23F);
  --grad4:linear-gradient(135deg,#A8FF3E,#00F5D4);
  --grad5:linear-gradient(135deg,#FF3CAC,#FF6B35);
  --bg:#070710; --sidebar-w:230px;
  --glass:rgba(255,255,255,0.06); --glass-b:rgba(255,255,255,0.12);
  --text:#f0f0ff; --muted:rgba(240,240,255,0.45);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Cabinet Grotesk',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;cursor:none;}

/* CURSOR */
#cur{position:fixed;width:12px;height:12px;background:var(--pink);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .3s,height .3s,background .3s;mix-blend-mode:screen;}
#trail{position:fixed;width:38px;height:38px;border:1.5px solid rgba(255,60,172,.5);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:left .13s ease,top .13s ease,width .3s,height .3s;}
body:has(.pin:hover) #cur{width:22px;height:22px;background:var(--cyan);}
body:has(.pin:hover) #trail{width:64px;height:64px;border-color:rgba(0,245,212,.4);}
body:has(.flip-wrap:hover) #cur{width:22px;height:22px;background:var(--yellow);}

/* BG */
.bg-scene{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;}
.bg-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,60,172,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,60,172,.04) 1px,transparent 1px);background-size:60px 60px;animation:gridDrift 30s linear infinite;}
@keyframes gridDrift{to{background-position:60px 60px;}}
.orb{position:absolute;border-radius:50%;filter:blur(90px);opacity:.16;}
.o1{width:600px;height:600px;background:var(--pink);top:-200px;left:-150px;animation:orbA 16s ease-in-out infinite alternate;}
.o2{width:500px;height:500px;background:var(--blue);bottom:-150px;right:-100px;animation:orbA 20s ease-in-out infinite alternate-reverse;}
.o3{width:350px;height:350px;background:var(--cyan);top:35%;left:35%;animation:orbA 12s ease-in-out infinite alternate;}
.o4{width:280px;height:280px;background:var(--orange);top:15%;right:25%;animation:orbA 14s ease-in-out infinite alternate-reverse;}
.o5{width:200px;height:200px;background:var(--lime);bottom:20%;left:20%;animation:orbA 10s ease-in-out infinite alternate;}
@keyframes orbA{0%{transform:translate(0,0) scale(1);}100%{transform:translate(50px,40px) scale(1.15);}}

/* SIDEBAR */
.sidebar{position:fixed;left:0;top:0;bottom:0;width:var(--sidebar-w);background:rgba(7,7,16,.78);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);border-right:1px solid var(--glass-b);z-index:200;display:flex;flex-direction:column;padding:24px 0;transition:transform .4s cubic-bezier(.4,0,.2,1);}
.logo{display:flex;align-items:center;gap:11px;padding:0 22px 24px;border-bottom:1px solid var(--glass-b);font-family:'Syne',sans-serif;font-size:21px;font-weight:800;}
.logo-mark{width:38px;height:38px;border-radius:12px;background:var(--grad1);display:flex;align-items:center;justify-content:center;font-size:19px;box-shadow:0 0 24px rgba(255,60,172,.55);animation:logoPulse 3s ease infinite;}
@keyframes logoPulse{0%,100%{box-shadow:0 0 24px rgba(255,60,172,.55);}50%{box-shadow:0 0 44px rgba(255,60,172,.85),0 0 80px rgba(255,60,172,.2);}}
.logo-txt{background:var(--grad1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.s-label{padding:18px 22px 6px;font-size:9px;font-weight:700;letter-spacing:2.5px;color:var(--muted);text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:11px;padding:10px 22px;color:var(--muted);cursor:pointer;border-radius:0 50px 50px 0;margin-right:14px;font-size:13.5px;font-weight:500;transition:all .3s cubic-bezier(.4,0,.2,1);position:relative;}
.nav-item:hover,.nav-item.active{color:var(--text);background:var(--glass);}
.nav-item.active::before{content:'';position:absolute;left:0;top:20%;height:60%;width:3px;background:var(--grad1);border-radius:0 4px 4px 0;}
.nav-ic{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;transition:all .3s;flex-shrink:0;}
.nav-item.active .nav-ic,.nav-item:hover .nav-ic{background:var(--glass);box-shadow:0 0 14px rgba(255,60,172,.3);}
.cat-item{display:flex;align-items:center;gap:9px;padding:7px 22px;cursor:pointer;color:var(--muted);font-size:12.5px;transition:all .3s;}
.cat-item:hover{color:var(--text);}
.cat-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.s-footer{margin-top:auto;padding:18px 22px;border-top:1px solid var(--glass-b);}
.user-row{display:flex;align-items:center;gap:10px;}
.u-ava{width:34px;height:34px;border-radius:50%;background:var(--grad1);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;box-shadow:0 0 16px rgba(255,60,172,.4);flex-shrink:0;}
.u-name{font-size:13px;font-weight:600;}
.u-handle{font-size:11px;color:var(--muted);}

/* MAIN */
.main{margin-left:var(--sidebar-w);position:relative;z-index:1;min-height:100vh;}

/* TOPBAR */
.topbar{position:sticky;top:0;z-index:100;padding:14px 28px;background:rgba(7,7,16,.68);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid var(--glass-b);display:flex;align-items:center;gap:14px;}
.search-wrap{flex:1;max-width:520px;position:relative;}
.search-input{width:100%;padding:12px 18px 12px 46px;background:rgba(255,255,255,.065);border:1px solid var(--glass-b);border-radius:50px;color:var(--text);font-family:'Cabinet Grotesk',sans-serif;font-size:14px;outline:none;transition:all .35s;backdrop-filter:blur(10px);}
.search-input::placeholder{color:var(--muted);}
.search-input:focus{border-color:rgba(255,60,172,.55);background:rgba(255,255,255,.1);box-shadow:0 0 0 3px rgba(255,60,172,.1),0 0 32px rgba(255,60,172,.08);}
.s-ic{position:absolute;left:15px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:16px;pointer-events:none;}
.tb-actions{display:flex;align-items:center;gap:9px;margin-left:auto;}
.ic-btn{width:38px;height:38px;border-radius:50%;background:var(--glass);border:1px solid var(--glass-b);color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;transition:all .3s;position:relative;}
.ic-btn:hover{color:var(--text);background:rgba(255,255,255,.12);border-color:rgba(255,60,172,.4);transform:scale(1.08);}
.notif-dot{position:absolute;top:6px;right:6px;width:8px;height:8px;border-radius:50%;background:var(--pink);border:2px solid var(--bg);animation:ping 2s ease infinite;}
@keyframes ping{0%,100%{box-shadow:0 0 0 0 rgba(255,60,172,.6);}50%{box-shadow:0 0 0 7px rgba(255,60,172,0);}}
.create-btn{display:flex;align-items:center;gap:7px;padding:10px 22px;border-radius:50px;background:var(--grad1);color:#fff;font-size:13px;font-weight:700;cursor:pointer;border:none;font-family:'Cabinet Grotesk',sans-serif;box-shadow:0 4px 22px rgba(255,60,172,.35);transition:all .3s;}
.create-btn:hover{transform:translateY(-2px) scale(1.04);box-shadow:0 8px 34px rgba(255,60,172,.55);}

/* FILTER */
.filter-bar{padding:14px 28px;display:flex;align-items:center;gap:9px;overflow-x:auto;scrollbar-width:none;}
.filter-bar::-webkit-scrollbar{display:none;}
.f-tab{padding:7px 18px;border-radius:50px;background:var(--glass);border:1px solid var(--glass-b);color:var(--muted);font-size:13px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all .3s;backdrop-filter:blur(8px);}
.f-tab:hover{color:var(--text);border-color:rgba(255,255,255,.22);}
.f-tab.active{background:var(--grad1);border-color:transparent;color:#fff;box-shadow:0 4px 18px rgba(255,60,172,.35);}

/* HERO */
.hero{margin:16px 28px 0;padding:44px 40px;border-radius:28px;background:rgba(255,255,255,.04);border:1px solid var(--glass-b);backdrop-filter:blur(20px);position:relative;overflow:hidden;animation:heroIn .9s cubic-bezier(.22,1,.36,1) both;}
@keyframes heroIn{from{opacity:0;transform:translateY(-22px) rotateX(5deg);}to{opacity:1;transform:translateY(0) rotateX(0);}}
.hero-shapes{position:absolute;inset:0;pointer-events:none;overflow:hidden;}
.hs{position:absolute;border-radius:50%;filter:blur(50px);opacity:.22;}
.hs1{width:260px;height:260px;background:var(--pink);right:-60px;top:-80px;animation:orbA 8s ease infinite alternate;}
.hs2{width:180px;height:180px;background:var(--cyan);left:30%;bottom:-50px;animation:orbA 10s ease infinite alternate-reverse;}
.hs3{width:140px;height:140px;background:var(--orange);left:60%;top:10%;animation:orbA 7s ease infinite alternate;}
.hero-content{position:relative;z-index:2;max-width:540px;}
.hero-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:50px;background:rgba(255,60,172,.18);border:1px solid rgba(255,60,172,.35);font-size:11px;font-weight:700;letter-spacing:1.2px;color:var(--pink);text-transform:uppercase;margin-bottom:14px;animation:badgePop .6s .3s both cubic-bezier(.34,1.56,.64,1);}
@keyframes badgePop{from{opacity:0;transform:scale(.7);}to{opacity:1;transform:scale(1);}}
.hero-title{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;line-height:1.15;margin-bottom:12px;}
.g1{background:var(--grad1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.g2{background:var(--grad4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.hero-desc{font-size:15px;color:var(--muted);line-height:1.65;margin-bottom:24px;}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;}
.btn-p{padding:12px 28px;border-radius:50px;background:var(--grad1);color:#fff;font-size:13px;font-weight:700;cursor:pointer;border:none;font-family:'Cabinet Grotesk',sans-serif;box-shadow:0 4px 22px rgba(255,60,172,.38);transition:all .3s;}
.btn-p:hover{transform:translateY(-3px);box-shadow:0 10px 38px rgba(255,60,172,.55);}
.btn-g{padding:12px 28px;border-radius:50px;background:rgba(255,255,255,.07);border:1px solid var(--glass-b);color:var(--text);font-size:13px;font-weight:700;cursor:pointer;font-family:'Cabinet Grotesk',sans-serif;transition:all .3s;}
.btn-g:hover{background:rgba(255,255,255,.13);border-color:rgba(255,255,255,.28);}
.hero-float-cards{position:absolute;right:44px;top:50%;transform:translateY(-50%);display:flex;gap:14px;align-items:flex-end;}
.hfc{width:90px;height:120px;border-radius:16px;overflow:hidden;border:1px solid var(--glass-b);box-shadow:0 20px 50px rgba(0,0,0,.5);transition:transform .4s ease;}
.hfc:nth-child(1){transform:rotate(-8deg) translateY(10px);}
.hfc:nth-child(2){transform:rotate(0) translateY(0) scale(1.08);z-index:2;}
.hfc:nth-child(3){transform:rotate(8deg) translateY(10px);}
.hfc:hover{transform:rotate(0) translateY(-12px) scale(1.14)!important;z-index:5;}
.hfc img{width:100%;height:100%;object-fit:cover;}

/* SECTION HEAD */
.sec-head{padding:10px 28px 4px;display:flex;align-items:center;justify-content:space-between;}
.sec-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;}
.sec-title span{background:var(--grad1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.sec-sub{font-size:12px;color:var(--muted);margin-top:2px;}
.see-all{font-size:12px;color:var(--muted);cursor:pointer;padding:6px 14px;border-radius:50px;border:1px solid var(--glass-b);transition:all .3s;}
.see-all:hover{color:var(--text);border-color:rgba(255,60,172,.4);}

/* MASONRY */
.grid-wrap{padding:8px 22px 48px;}
.masonry{columns:5;column-gap:14px;}
@media(max-width:1500px){.masonry{columns:4;}}
@media(max-width:1150px){.masonry{columns:3;}}
@media(max-width:780px){.masonry{columns:2;}}

/* ── PIN CARD ── */
.pin{break-inside:avoid;margin-bottom:14px;position:relative;border-radius:22px;overflow:visible;cursor:none;opacity:0;transform:translateY(70px) scale(.9) rotateX(14deg);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);transform-style:preserve-3d;perspective:900px;will-change:transform,opacity;}
.pin.visible{opacity:1;transform:translateY(0) scale(1) rotateX(0);}
.pin-inner{border-radius:22px;overflow:hidden;position:relative;transform-style:preserve-3d;box-shadow:0 8px 30px rgba(0,0,0,.4);transition:box-shadow .4s;}
.pin:hover .pin-inner{box-shadow:0 26px 64px rgba(0,0,0,.65),0 0 40px rgba(255,60,172,.14);}
.pin-img{width:100%;display:block;object-fit:cover;transition:transform .6s cubic-bezier(.22,1,.36,1);}
.pin:hover .pin-img{transform:scale(1.07);}
.pin-gloss{position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.18) 0%,transparent 50%,rgba(0,0,0,.08) 100%);opacity:0;transition:opacity .4s;pointer-events:none;border-radius:22px;}
.pin:hover .pin-gloss{opacity:1;}
.pin-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 30%,rgba(0,0,0,.83) 100%);opacity:0;transition:opacity .35s;border-radius:22px;display:flex;flex-direction:column;justify-content:flex-end;padding:16px;}
.pin:hover .pin-overlay{opacity:1;}
.pin-depth-badge{position:absolute;top:-10px;left:14px;transform:translateZ(30px);padding:4px 11px;border-radius:50px;font-size:9px;font-weight:800;letter-spacing:1px;text-transform:uppercase;border:1px solid rgba(255,255,255,.2);backdrop-filter:blur(10px);opacity:0;transition:opacity .3s,transform .3s;pointer-events:none;box-shadow:0 6px 20px rgba(0,0,0,.3);}
.pin:hover .pin-depth-badge{opacity:1;transform:translateZ(44px) translateY(-4px);}
.db-pink{background:rgba(255,60,172,.35);color:#FF3CAC;}
.db-cyan{background:rgba(0,245,212,.2);color:#00F5D4;}
.db-orange{background:rgba(255,107,53,.3);color:#FF6B35;}
.db-lime{background:rgba(168,255,62,.2);color:#A8FF3E;}
.pin-save{position:absolute;top:12px;right:12px;padding:8px 18px;border-radius:50px;background:var(--grad1);color:#fff;font-size:12px;font-weight:700;border:none;cursor:none;box-shadow:0 4px 18px rgba(255,60,172,.5);font-family:'Cabinet Grotesk',sans-serif;opacity:0;transform:translateY(-8px);transition:all .3s cubic-bezier(.34,1.56,.64,1);}
.pin:hover .pin-save{opacity:1;transform:translateY(0);}
.pin-more{position:absolute;top:12px;right:92px;width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,.13);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.2);color:#fff;font-size:16px;cursor:none;display:flex;align-items:center;justify-content:center;opacity:0;transition:all .3s;}
.pin:hover .pin-more{opacity:1;}
.pin-title{font-size:13px;font-weight:600;color:#fff;line-height:1.4;margin-bottom:6px;text-shadow:0 2px 10px rgba(0,0,0,.5);}
.pin-meta{display:flex;align-items:center;gap:7px;}
.pin-ava{width:22px;height:22px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;}
.pin-author{font-size:11px;color:rgba(255,255,255,.8);font-weight:500;}
.pin-like{position:absolute;bottom:12px;right:12px;display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:50px;background:rgba(255,255,255,.14);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.9);font-size:12px;font-weight:600;cursor:none;transition:all .3s;opacity:0;}
.pin:hover .pin-like{opacity:1;}
.pin-like:hover{background:rgba(255,60,172,.35);border-color:rgba(255,60,172,.5);}
.pin-like.liked{color:#FF3CAC;}

/* ── FLIP CARD ── */
.flip-wrap{break-inside:avoid;margin-bottom:14px;perspective:1000px;cursor:none;opacity:0;transform:translateY(70px) scale(.9);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);will-change:transform,opacity;}
.flip-wrap.visible{opacity:1;transform:translateY(0) scale(1);}
.flip-card{position:relative;width:100%;transform-style:preserve-3d;transition:transform .75s cubic-bezier(.4,0,.2,1);}
.flip-wrap:hover .flip-card{transform:rotateY(180deg);}
.flip-front,.flip-back{position:absolute;top:0;left:0;width:100%;backface-visibility:hidden;border-radius:22px;overflow:hidden;}
.flip-front img{width:100%;display:block;object-fit:cover;border-radius:22px;}
.flip-back{transform:rotateY(180deg);background:linear-gradient(135deg,#13131e,#1a1a30);border:1px solid var(--glass-b);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:22px;text-align:center;gap:10px;}
.flip-back-icon{font-size:38px;}
.flip-back-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;background:var(--grad1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.flip-back-desc{font-size:12px;color:var(--muted);line-height:1.55;}
.flip-back-btn{margin-top:6px;padding:8px 20px;border-radius:50px;background:var(--grad1);color:#fff;font-size:12px;font-weight:700;border:none;cursor:none;font-family:'Cabinet Grotesk',sans-serif;box-shadow:0 4px 16px rgba(255,60,172,.4);}

/* SCROLL DOTS */
.scroll-dots{position:fixed;right:24px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:8px;z-index:300;}
.sdot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.2);transition:all .4s;cursor:pointer;}
.sdot.active{width:10px;height:28px;border-radius:5px;background:var(--grad1);border-color:transparent;box-shadow:0 0 14px rgba(255,60,172,.5);}

/* LOAD MORE */
.load-more{display:flex;justify-content:center;padding:10px 0 40px;}
.spinner{width:38px;height:38px;border-radius:50%;border:3px solid rgba(255,255,255,.07);border-top-color:var(--pink);animation:spin .8s linear infinite;display:none;}
@keyframes spin{to{transform:rotate(360deg);}}

::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:4px;}
::-webkit-scrollbar-thumb:hover{background:rgba(255,60,172,.4);}

.mob-menu{display:none;width:38px;height:38px;border-radius:10px;background:var(--glass);border:1px solid var(--glass-b);color:var(--text);cursor:pointer;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
@media(max-width:780px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:translateX(0);}
  .main{margin-left:0;}
  .mob-menu{display:flex;}
  .masonry{columns:2;}
  .hero{margin:12px 14px 0;padding:24px 20px;}
  .hero-title{font-size:24px;}
  .hero-float-cards{display:none;}
  .topbar,.filter-bar,.grid-wrap,.sec-head{padding-left:14px;padding-right:14px;}
  #cur,#trail{display:none;}
  body{cursor:auto;}
  .pin,.flip-wrap{cursor:pointer;}
  .pin-save,.pin-more,.flip-back-btn{cursor:pointer;}
  .scroll-dots{display:none;}
}
</style>
</head>
<body>

<div id="cur"></div>
<div id="trail"></div>

<div class="bg-scene">
  <div class="bg-grid"></div>
  <div class="orb o1"></div><div class="orb o2"></div>
  <div class="orb o3"></div><div class="orb o4"></div><div class="orb o5"></div>
</div>

<div class="scroll-dots" id="scrollDots">
  <div class="sdot active"></div><div class="sdot"></div>
  <div class="sdot"></div><div class="sdot"></div>
</div>


<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <div class="logo">
    <div class="logo-mark">✦</div>
    <span class="logo-txt">Pinspire</span>
  </div>
  <div class="s-label">Navigate</div>
  <div class="nav-item active" onclick="setNav(this)"><div class="nav-ic">🏠</div>Home</div>
  <div class="nav-item" onclick="setNav(this)"><div class="nav-ic">🔍</div>Explore</div>
  <div class="nav-item" onclick="setNav(this)"><div class="nav-ic">✨</div>Following</div>
  <div class="nav-item" onclick="setNav(this)"><div class="nav-ic">📌</div>Saved</div>
  <div class="nav-item" onclick="setNav(this)"><div class="nav-ic">🎨</div>Create</div>
  <div class="s-label">Categories</div>
  <div class="cat-item"><div class="cat-dot" style="background:#FF3CAC"></div>Art & Design</div>
  <div class="cat-item"><div class="cat-dot" style="background:#00F5D4"></div>Architecture</div>
