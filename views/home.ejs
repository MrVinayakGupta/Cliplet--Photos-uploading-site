<script>
/* DATA */
const PINS = [
  {img:"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=500&q=80",h:290,title:"Neon Architecture Tokyo",author:"Yuki M.",av:"#FF3CAC",badge:"Trending",bc:"db-pink",likes:"4.2k",flip:false},
  {img:"https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=500&q=80",h:350,title:"Abstract Digital Art",author:"Sara K.",av:"#784BA0",badge:"Featured",bc:"db-lime",likes:"2.1k",flip:true,fi:"🎨",fd:"Abstract gradients from Sara's latest collection. Hover to explore.",fh:350},
  {img:"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=500&q=80",h:260,title:"Mountain Sunrise Vista",author:"Tom W.",av:"#2B86C5",badge:"New",bc:"db-cyan",likes:"5.8k",flip:false},
  {img:"https://images.unsplash.com/photo-1550745165-9bc0b252726f?w=500&q=80",h:375,title:"Retro Synthwave Vibes",author:"Nina B.",av:"#00F5D4",badge:"Trending",bc:"db-pink",likes:"3.4k",flip:false},
  {img:"https://images.unsplash.com/photo-1541701494587-cb58502866ab?w=500&q=80",h:310,title:"Abstract Fluid Colors",author:"Leo A.",av:"#FF6B35",badge:"Popular",bc:"db-orange",likes:"1.9k",flip:true,fi:"🌊",fd:"Fluid art prints from Leo's studio. Available as wallpapers.",fh:310},
  {img:"https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=500&q=80",h:250,title:"Clean Minimal Workspace",author:"Ann R.",av:"#A8FF3E",badge:"New",bc:"db-lime",likes:"6.1k",flip:false},
  {img:"https://images.unsplash.com/photo-1493246507139-91e8fad9978e?w=500&q=80",h:395,title:"Foggy Forest Path",author:"Chris M.",av:"#FF3CAC",badge:"Featured",bc:"db-cyan",likes:"2.7k",flip:false},
  {img:"https://images.unsplash.com/photo-1567016432779-094069958ea5?w=500&q=80",h:300,title:"Cozy Interior Design",author:"Mia S.",av:"#784BA0",badge:"Popular",bc:"db-orange",likes:"4.5k",flip:true,fi:"🛋️",fd:"Cozy interiors curated by Mia — save for your next redesign.",fh:300},
  {img:"https://images.unsplash.com/photo-1484515991647-c5760fcecfc7?w=500&q=80",h:330,title:"Golden Hour Portrait",author:"Jake L.",av:"#2B86C5",badge:"Trending",bc:"db-pink",likes:"8.3k",flip:false},
  {img:"https://images.unsplash.com/photo-1582719471384-894fbb16e074?w=500&q=80",h:280,title:"Ocean Wave Photography",author:"Eva D.",av:"#00F5D4",badge:"New",bc:"db-cyan",likes:"3.9k",flip:false},
  {img:"https://images.unsplash.com/photo-1561070791-2526d30994b5?w=500&q=80",h:360,title:"Geometric UI Concept",author:"Ryo T.",av:"#FF6B35",badge:"Featured",bc:"db-lime",likes:"5.2k",flip:true,fi:"💎",fd:"UI geometry concepts by Ryo — templates available to download.",fh:360},
  {img:"https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=500&q=80",h:270,title:"City Nightscape",author:"Kai H.",av:"#A8FF3E",badge:"Popular",bc:"db-orange",likes:"7.1k",flip:false},
  {img:"https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=500&q=80",h:320,title:"Luxury Living Space",author:"Isla P.",av:"#FF3CAC",badge:"Trending",bc:"db-pink",likes:"2.8k",flip:false},
  {img:"https://images.unsplash.com/photo-1567722066597-a58a6fd7e2ca?w=500&q=80",h:290,title:"Tropical Drone View",author:"Finn O.",av:"#784BA0",badge:"New",bc:"db-cyan",likes:"4.0k",flip:false},
  {img:"https://images.unsplash.com/photo-1484723091739-30a097e8f929?w=500&q=80",h:340,title:"Artisan Food Styling",author:"Luna B.",av:"#2B86C5",badge:"Popular",bc:"db-orange",likes:"3.3k",flip:true,fi:"🍽️",fd:"Food styling tips & recipes by Luna. Hover for more.",fh:340},
  {img:"https://images.unsplash.com/photo-1513836279014-a89f7a76ae86?w=500&q=80",h:300,title:"Autumn Forest Light",author:"Seb V.",av:"#00F5D4",badge:"Featured",bc:"db-lime",likes:"6.4k",flip:false},
  {img:"https://images.unsplash.com/photo-1547036967-23d11aacaee0?w=500&q=80",h:270,title:"Desert Sunrise Dunes",author:"Zara M.",av:"#FF6B35",badge:"Trending",bc:"db-pink",likes:"5.0k",flip:false},
  {img:"https://images.unsplash.com/photo-1607604276583-eef5d076aa5f?w=500&q=80",h:385,title:"Minimalist Brand Design",author:"Owen L.",av:"#A8FF3E",badge:"New",bc:"db-cyan",likes:"1.6k",flip:false},
  {img:"https://images.unsplash.com/photo-1527004013197-933c4bb611b3?w=500&q=80",h:290,title:"Snow Mountain Peak",author:"Nia F.",av:"#FF3CAC",badge:"Popular",bc:"db-orange",likes:"9.2k",flip:false},
  {img:"https://images.unsplash.com/photo-1523821741446-edb2b68bb7a0?w=500&q=80",h:325,title:"Pastel Street Fashion",author:"Eli T.",av:"#784BA0",badge:"Featured",bc:"db-lime",likes:"3.7k",flip:true,fi:"👗",fd:"Street fashion lookbook by Eli — new season drops weekly.",fh:325},
];

/* BUILD PIN */
function buildPin(p) {
  const div = document.createElement('div');
  div.className = 'pin';
  div.innerHTML = `
    <div class="pin-inner">
      <img class="pin-img" src="${p.img}" alt="${p.title}" style="height:${p.h}px" loading="lazy"/>
      <div class="pin-gloss"></div>
      <div class="pin-overlay">
        <div class="pin-title">${p.title}</div>
        <div class="pin-meta">
          <div class="pin-ava" style="background:${p.av}">${p.author[0]}</div>
          <span class="pin-author">${p.author}</span>
        </div>
      </div>
      <button class="pin-save">Save</button>
      <button class="pin-more">⋯</button>
      <div class="pin-depth-badge ${p.bc}">${p.badge}</div>
      <button class="pin-like" onclick="toggleLike(this,event)">♡ ${p.likes}</button>
    </div>`;
  // 3D tilt on hover
  const inner = div.querySelector('.pin-inner');
  div.addEventListener('mousemove', e => {
    const r = div.getBoundingClientRect();
    const x = (e.clientX - r.left) / r.width  - 0.5;
    const y = (e.clientY - r.top)  / r.height - 0.5;
    inner.style.transform = `rotateY(${x*20}deg) rotateX(${-y*16}deg) scale(1.04)`;
    inner.style.transition = 'transform .08s ease';
  });
  div.addEventListener('mouseleave', () => {
    inner.style.transform = '';
    inner.style.transition = 'transform .55s cubic-bezier(.22,1,.36,1)';
  });
  return div;
}

/* BUILD FLIP */
function buildFlip(p) {
  const wrap = document.createElement('div');
  wrap.className = 'flip-wrap';
  wrap.innerHTML = `
    <div class="flip-card" style="height:${p.fh}px">
      <div class="flip-front" style="height:${p.fh}px">
        <img src="${p.img}" alt="${p.title}" style="height:${p.fh}px;width:100%;object-fit:cover"/>
      </div>
      <div class="flip-back" style="height:${p.fh}px">
        <div class="flip-back-icon">${p.fi}</div>
        <div class="flip-back-title">${p.title}</div>
        <div class="flip-back-desc">${p.fd}</div>
        <button class="flip-back-btn">Save to Board</button>
      </div>
    </div>`;
  return wrap;
}

const grid = document.getElementById('grid');

function renderBatch(data) {
  data.forEach(p => {
    const el = p.flip ? buildFlip(p) : buildPin(p);
    grid.appendChild(el);
  });
  observeCards();
}

renderBatch(PINS);

/* INTERSECTION OBSERVER — staggered cascade */
function observeCards() {
  const io = new IntersectionObserver(entries => {
    // group visible entries and stagger them
    const visible = entries.filter(e => e.isIntersecting);
    visible.forEach((entry, i) => {
      const el = entry.target;
      setTimeout(() => {
        el.classList.add('visible');
        const fc = el.querySelector('.flip-card');
        if (fc) fc.classList.add('visible');
      }, i * 75);
      io.unobserve(el);
    });
  }, {threshold: 0.07, rootMargin: '0px 0px -30px 0px'});

  document.querySelectorAll('.pin:not(.visible), .flip-wrap:not(.visible)').forEach(el => io.observe(el));
}

/* CURSOR */
const cur = document.getElementById('cur');
const trail = document.getElementById('trail');
document.addEventListener('mousemove', e => {
  cur.style.left = e.clientX + 'px'; cur.style.top = e.clientY + 'px';
  trail.style.left = e.clientX + 'px'; trail.style.top = e.clientY + 'px';
});

/* LIKE */
function toggleLike(btn, e) {
  e.stopPropagation();
  btn.classList.toggle('liked');
  const p = btn.textContent.split(' ');
  btn.textContent = (btn.classList.contains('liked') ? '♥' : '♡') + ' ' + p[1];
}

/* FILTER TABS */
document.querySelectorAll('.f-tab').forEach(t => t.addEventListener('click', function() {
  document.querySelectorAll('.f-tab').forEach(x => x.classList.remove('active'));
  this.classList.add('active');
}));

/* NAV */
function setNav(el) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
}

/* MOBILE */
document.getElementById('menuBtn').addEventListener('click', () => document.getElementById('sidebar').classList.toggle('open'));
document.addEventListener('click', e => {
  const sb = document.getElementById('sidebar');
  if (!sb.contains(e.target) && e.target.id !== 'menuBtn') sb.classList.remove('open');
});

/* SEARCH */
document.getElementById('searchInput').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('.pin, .flip-wrap').forEach(card => {
    const t = card.querySelector('.pin-title, .flip-back-title');
    const match = !q || (t && t.textContent.toLowerCase().includes(q));
    card.style.opacity = match ? '' : '0.15';
    card.style.transform = match ? '' : 'scale(.93)';
    card.style.transition = 'opacity .3s, transform .3s';
  });
});

/* SCROLL DOTS */
const secs = ['sec0','sec1','sec2','sec3'];
const dots = document.querySelectorAll('.sdot');
dots.forEach((d, i) => d.addEventListener('click', () => document.getElementById(secs[i])?.scrollIntoView({behavior:'smooth'})));
const secIO = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const i = secs.indexOf(e.target.id);
      if (i >= 0) { dots.forEach(d => d.classList.remove('active')); dots[i]?.classList.add('active'); }
    }
  });
}, {threshold: .4});
secs.forEach(id => { const el = document.getElementById(id); if(el) secIO.observe(el); });

/* INFINITE SCROLL */
let loading = false;
const spinner = document.getElementById('spinner');
window.addEventListener('scroll', () => {
  if (window.scrollY + window.innerHeight >= document.body.scrollHeight - 400 && !loading) {
    loading = true; spinner.style.display = 'block';
    setTimeout(() => {
      renderBatch([...PINS].sort(() => Math.random() - .5).slice(0, 8));
      spinner.style.display = 'none';
      loading = false;
    }, 1000);
  }
});
</script>
</body>
</html>



